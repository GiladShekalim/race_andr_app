<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    tools:context=".MainActivity">

    <!-- Hearts (Lives) -->
    <LinearLayout
        android:id="@+id/main_LAY_hearts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="@dimen/heart_top_margin"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/main_IMG_heart0"
            android:layout_width="@dimen/heart_size"
            android:layout_height="@dimen/heart_size"
            android:layout_margin="@dimen/heart_margin"
            app:srcCompat="@drawable/money_bag" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/main_IMG_heart1"
            android:layout_width="@dimen/heart_size"
            android:layout_height="@dimen/heart_size"
            android:layout_margin="@dimen/heart_margin"
            app:srcCompat="@drawable/money_bag" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/main_IMG_heart2"
            android:layout_width="@dimen/heart_size"
            android:layout_height="@dimen/heart_size"
            android:layout_margin="@dimen/heart_margin"
            app:srcCompat="@drawable/money_bag" />
    </LinearLayout>

    <!-- Obstacles (Placeholders) -->
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/main_IMG_obstacle0"
        android:layout_width="@dimen/obstacle_size"
        android:layout_height="@dimen/obstacle_size"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="100dp"
        app:srcCompat="@drawable/fuel" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/main_IMG_obstacle1"
        android:layout_width="@dimen/obstacle_size"
        android:layout_height="@dimen/obstacle_size"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="200dp"
        android:layout_marginEnd="50dp"
        app:srcCompat="@drawable/clinic" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/main_IMG_obstacle2"
        android:layout_width="@dimen/obstacle_size"
        android:layout_height="@dimen/obstacle_size"
        android:layout_alignParentStart="true"
        android:layout_marginStart="40dp"
        android:layout_marginTop="300dp"
        app:srcCompat="@drawable/no_tax" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/main_IMG_obstacle3"
        android:layout_width="@dimen/obstacle_size"
        android:layout_height="@dimen/obstacle_size"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="450dp"
        app:srcCompat="@drawable/broken_car" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/main_IMG_obstacle4"
        android:layout_width="@dimen/obstacle_size"
        android:layout_height="@dimen/obstacle_size"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="550dp"
        android:layout_marginEnd="32dp"
        app:srcCompat="@drawable/bankrupt" />

    <!-- Car (Player) -->
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/main_IMG_car"
        android:layout_width="@dimen/car_size"
        android:layout_height="@dimen/car_size"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="@dimen/car_bottom_margin"
        app:srcCompat="@drawable/racing_car" />

    <!-- Control Buttons -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/main_BTN_left"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_margin="@dimen/default_margin"
        android:text="LEFT"
        app:icon="@drawable/ic_left" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/main_BTN_right"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="@dimen/default_margin"
        android:text="RIGHT"
        app:icon="@drawable/ic_right" />

</RelativeLayout>