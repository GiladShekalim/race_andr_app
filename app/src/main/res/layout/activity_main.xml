<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    tools:context=".MainActivity">

    <!-- Hearts (Lives) -->
    <LinearLayout
        android:id="@+id/main_LAY_hearts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="@dimen/heart_top_margin"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/main_IMG_heart0"
            android:layout_width="@dimen/heart_size"
            android:layout_height="@dimen/heart_size"
            android:layout_margin="@dimen/heart_margin"
            app:srcCompat="@drawable/money_bag" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/main_IMG_heart1"
            android:layout_width="@dimen/heart_size"
            android:layout_height="@dimen/heart_size"
            android:layout_margin="@dimen/heart_margin"
            app:srcCompat="@drawable/money_bag" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/main_IMG_heart2"
            android:layout_width="@dimen/heart_size"
            android:layout_height="@dimen/heart_size"
            android:layout_margin="@dimen/heart_margin"
            app:srcCompat="@drawable/money_bag" />
    </LinearLayout>

    <!-- Game Matrix (3 columns x 8 rows) -->
    <LinearLayout
        android:id="@+id/main_LAY_matrix"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/main_BTN_left"
        android:layout_below="@id/main_LAY_hearts"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="@dimen/default_margin"
        android:layout_marginTop="@dimen/default_margin"
        android:orientation="vertical"
        android:weightSum="8">

        <!-- Obstacle Row 0 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_0_0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/fuel" />
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_0_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/fuel" />
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_0_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/fuel" />
        </LinearLayout>

        <!-- Obstacle Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_1_0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/clinic" />
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_1_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/clinic" />
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_1_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/clinic" />
        </LinearLayout>

        <!-- Obstacle Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_2_0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/no_tax" />
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_2_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/no_tax" />
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_2_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/no_tax" />
        </LinearLayout>

        <!-- Obstacle Row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_3_0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/broken_car" />
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_3_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/broken_car" />
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_3_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/broken_car" />
        </LinearLayout>

        <!-- Obstacle Row 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_4_0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/bankrupt" />
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_4_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/bankrupt" />
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_4_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/bankrupt" />
        </LinearLayout>

        <!-- Obstacle Row 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_5_0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/fuel" />
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_5_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/fuel" />
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_5_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/fuel" />
        </LinearLayout>

        <!-- Obstacle Row 6 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_6_0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/clinic" />
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_6_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/clinic" />
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_obstacle_6_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                tools:srcCompat="@drawable/clinic" />
        </LinearLayout>

        <!-- Car Row (Row 7) -->
        <LinearLayout
            android:id="@+id/main_LAY_car_row"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_car_0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                app:srcCompat="@drawable/racing_car" />
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_car_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="visible"
                app:srcCompat="@drawable/racing_car" />
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/main_IMG_car_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible"
                app:srcCompat="@drawable/racing_car" />
        </LinearLayout>
    </LinearLayout>

    <!-- Control Buttons -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/main_BTN_left"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_margin="@dimen/default_margin"
        android:text="LEFT"
        app:icon="@drawable/ic_left" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/main_BTN_right"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="@dimen/default_margin"
        android:text="RIGHT"
        app:icon="@drawable/ic_right" />

    <!-- Money Lost Overlay Text -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/main_LBL_money_lost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="@string/money_lost"
        android:textSize="40sp"
        android:textStyle="bold"
        android:textColor="@android:color/holo_red_dark"
        android:alpha="0.7"
        android:visibility="gone"
        android:elevation="10dp" />

</RelativeLayout>